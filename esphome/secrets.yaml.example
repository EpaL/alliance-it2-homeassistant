# Copy to secrets.yaml (same folder) and fill in. Never commit the real one.
wifi_ssid: "YourWiFiName"
wifi_password: "your-wifi-password"

# API key: 32-byte base64. Generate with:  openssl rand -base64 32
# (or let the ESPHome dashboard generate it when you adopt the device)
api_key: "REPLACE_WITH_BASE64_KEY"

# OTA password: any strong string you choose
ota_password: "REPLACE_WITH_A_PASSWORD"
