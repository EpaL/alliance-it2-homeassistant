# it2_bridge configuration — copy to /etc/it2_bridge.env on the Pi and edit.
# All values are read as environment variables by the systemd service.

# --- MQTT broker (the Mosquitto add-on in Home Assistant) ---
MQTT_HOST=192.168.1.10          # your HA / broker IP
MQTT_PORT=1883
MQTT_USERNAME=it2bridge          # an MQTT user you create in HA
MQTT_PASSWORD=change-me

# --- the it2 device ---
DEVICE_NAME=Alliance             # BLE advertised name (the it2 shows as "Alliance")
# DEVICE_ADDRESS=AA:BB:CC:DD:EE:FF  # optional: set the MAC to skip scanning (faster/robust)

# --- Home Assistant entity ---
NODE_ID=it2_garden               # unique id + MQTT topic root
FRIENDLY_NAME=Garden Lighting
MODEL=it2-300
DISCOVERY_PREFIX=homeassistant   # must match HA's MQTT discovery prefix (default)

# --- behaviour ---
POLL_INTERVAL=30                 # seconds between state polls over BLE
ENABLE_BRIGHTNESS=false          # experimental (opcode 82); leave false until verified
LOG_LEVEL=INFO                   # DEBUG to see every BLE frame
